steps:
  # --- Booking Service ---
  - name: "gcr.io/cloud-builders/docker"
    args:
      [
        "build",
        "-t",
        "gcr.io/$PROJECT_ID/booking-service:latest",
        "-f",
        "./booking-service/Dockerfile.deploy",
        "./booking-service",
      ]
  - name: "gcr.io/cloud-builders/docker"
    args: ["push", "gcr.io/$PROJECT_ID/booking-service:latest"]
  - name: "gcr.io/google.com/cloudsdktool/cloud-sdk"
    entrypoint: "gcloud"
    args:
      [
        "run",
        "deploy",
        "booking-service",
        "--image",
        "gcr.io/$PROJECT_ID/booking-service:latest",
        "--region",
        "us-central1",
        "--platform",
        "managed",
        "--allow-unauthenticated",
        "--memory",
        "512Mi",
        "--set-env-vars",
        "BOOKING_DB_URL=$BOOKING_DB_URL,BOOKING_DB_USERNAME=$BOOKING_DB_USERNAME,SPRING_JPA_HIBERNATE_DDL_AUTO=$SPRING_JPA_HIBERNATE_DDL_AUTO,JWT_EXPIRATION=$JWT_EXPIRATION,RESOURCE_SERVICE_URL=$RESOURCE_SERVICE_URL,RABBITMQ_HOST=$RABBITMQ_HOST,RABBITMQ_PORT=$RABBITMQ_PORT,RABBITMQ_USERNAME=$RABBITMQ_USERNAME,RABBITMQ_PASSWORD=$RABBITMQ_PASSWORD,STRIPE_TEST_SECRET=$STRIPE_TEST_SECRET,STRIPE_WEBHOOK_SECRET=$STRIPE_WEBHOOK_SECRET,JWT_SECRET=$JWT_SECRET",
        "--set-secrets",
        "BOOKING_DB_PASSWORD=projects/$PROJECT_ID/secrets/BOOKING_DB_PASSWORD:latest,JWT_SECRET=projects/$PROJECT_ID/secrets/JWT_SECRET:latest,STRIPE_TEST_SECRET=projects/$PROJECT_ID/secrets/STRIPE_TEST_SECRET:latest,STRIPE_WEBHOOK_SECRET=projects/$PROJECT_ID/secrets/STRIPE_WEBHOOK_SECRET:latest",
      ]

  # --- Resource Service ---
  - name: "gcr.io/cloud-builders/docker"
    args:
      [
        "build",
        "-t",
        "gcr.io/$PROJECT_ID/resource-service:latest",
        "-f",
        "./resource-service/Dockerfile.deploy",
        "./resource-service",
      ]
  - name: "gcr.io/cloud-builders/docker"
    args: ["push", "gcr.io/$PROJECT_ID/resource-service:latest"]
  - name: "gcr.io/google.com/cloudsdktool/cloud-sdk"
    entrypoint: "gcloud"
    args:
      [
        "run",
        "deploy",
        "resource-service",
        "--image",
        "gcr.io/$PROJECT_ID/resource-service:latest",
        "--region",
        "us-central1",
        "--platform",
        "managed",
        "--allow-unauthenticated",
        "--memory",
        "256Mi",
        "--set-env-vars",
        "RESOURCE_DB_URL=$RESOURCE_DB_URL,RESOURCE_DB_USERNAME=$RESOURCE_DB_USERNAME,SPRING_JPA_HIBERNATE_DDL_AUTO=$SPRING_JPA_HIBERNATE_DDL_AUTO",
      ]

  # --- Notification Service ---
  - name: "gcr.io/cloud-builders/docker"
    args:
      [
        "build",
        "-t",
        "gcr.io/$PROJECT_ID/notification-service:latest",
        "-f",
        "./notification-service/Dockerfile.deploy",
        "./notification-service",
      ]
  - name: "gcr.io/cloud-builders/docker"
    args: ["push", "gcr.io/$PROJECT_ID/notification-service:latest"]
  - name: "gcr.io/google.com/cloudsdktool/cloud-sdk"
    entrypoint: "gcloud"
    args:
      [
        "run",
        "deploy",
        "notification-service",
        "--image",
        "gcr.io/$PROJECT_ID/notification-service:latest",
        "--region",
        "us-central1",
        "--platform",
        "managed",
        "--allow-unauthenticated",
        "--memory",
        "128Mi",
        "--set-env-vars",
        "NOTIFICATION_DB_URL=$NOTIFICATION_DB_URL,NOTIFICATION_DB_USERNAME=$NOTIFICATION_DB_USERNAME,SPRING_JPA_HIBERNATE_DDL_AUTO=$SPRING_JPA_HIBERNATE_DDL_AUTO,SENDER_EMAIL=$SENDER_EMAIL,RABBITMQ_HOST=$RABBITMQ_HOST,RABBITMQ_PORT=$RABBITMQ_PORT,RABBITMQ_USERNAME=$RABBITMQ_USERNAME,RABBITMQ_PASSWORD=$RABBITMQ_PASSWORD",
        "--set-secrets",
        "NOTIFICATION_DB_PASSWORD=projects/$PROJECT_ID/secrets/NOTIFICATION_DB_PASSWORD:latest,SENDER_EMAIL_PASSWORD=projects/$PROJECT_ID/secrets/SENDER_EMAIL_PASSWORD:latest",
      ]
